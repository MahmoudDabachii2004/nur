# ============================================================
# NUR — Environment Variables
# ------------------------------------------------------------
# Copy this file to `.env` and fill in your keys:
#   cp .env.example .env
#
# All cloud APIs used here have FREE tiers — no payment required.
#
# Source of truth for the values below:
#   - docs/RAG_PIPELINE_ARCHITECTURE.md  (LLM lineup, fallback chain)
#   - docs/PILLARS.md                    (languages, weighting, verification)
#   - src/nur/config.py                  (Pydantic Settings class — same keys)
#
# Every NUR_* variable maps 1:1 to a field on the `Settings` class
# via the `NUR_` env prefix. Do not invent new variables here without
# adding the matching field in config.py first.
# ============================================================

# ----- LLM Providers -----
# Groq — primary cloud LLM host (https://console.groq.com)
# Free tier covers: 30K TPM on Llama 4 Scout, 12K TPM on Llama 3.3 70B.
GROQ_API_KEY=

# OpenRouter — secondary cloud fallback (https://openrouter.ai)
# Not wired in Phase 2; reserved for Phase 9 (CRAG / adaptive routing).
OPENROUTER_API_KEY=

# Ollama — local offline fallback (no key needed, runs on localhost)
# Used when Groq returns 429 (Rate Limit Exceeded). The local PC is
# expected to have Ollama running with `llama3.1:8b` pulled.
OLLAMA_BASE_URL=http://localhost:11434

# ----- Model Selection (see docs/RAG_PIPELINE_ARCHITECTURE.md Section 3) -----
# Architect — Step 1, fast query decomposition into 1..N sub-questions.
NUR_LLM_ARCHITECT=llama-3.1-8b-instant
# Reporter   — Step 4, primary structured JSON generation. 30K TPM on Groq.
NUR_LLM_PRIMARY=meta-llama/llama-4-scout-17b-16e-instruct
# Reporter fallback for extreme Ikhtilaf (scholarly disagreement) cases.
# Slower (12K TPM) but deeper reasoning.
NUR_LLM_REASONING=llama-3.3-70b-versatile
# Offline fallback when Groq 429s. Runs via Ollama on the local PC.
NUR_LLM_LOCAL=llama3.1:8b

# ----- Embeddings -----
# BGE-M3 — multilingual (AR/FR/EN) dense (1024-dim) + sparse + ColBERT.
# Runs locally on Apple Silicon (MPS) during ingestion AND query encoding.
NUR_EMBEDDING_MODEL=BAAI/bge-m3
NUR_EMBEDDING_DIM=1024

# Reranker — bge-reranker-v2-m3 cross-encoder (Phase 3)
# 568M params, multilingual, runs locally on MPS.
NUR_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ----- Vector DB -----
# ChromaDB persistent path (local). Holds the 4 dense collections:
# quran_dense, hadith_dense, tafsir_ar_dense, tafsir_en_dense.
NUR_CHROMA_PATH=data/chroma_db

# ----- Retrieval Settings (see docs/RAG_PIPELINE_ARCHITECTURE.md Step 2) -----
# RRF fusion parameters:
#   k=25   — lower than the web-standard 60; better for short Islamic text chunks.
#   α=0.4  — dense weight; sparse gets 0.6 (exact keyword matches dominate).
NUR_RRF_K=25
NUR_RRF_ALPHA_DENSE=0.4

# Top-K counts at each pipeline stage:
#   INITIAL = post-RRF fusion, before reranker. 100 (Phase 3, DEC-031) — increased
#             from 30 to improve recall. More chunks = better chance of finding
#             direct verse proofs that the retriever might rank below tafsir chunks.
#   RERANK  = post-reranker, sent to the LLM. 10 (TPM-limited: 10 chunks × 1,660
#             tokens = 16,600 tokens = 59% of Scout's 30K TPM per query).
#   FINAL   = reserved for Phase 3+ display truncation.
NUR_TOP_K_INITIAL=100
NUR_TOP_K_RERANK=10
NUR_TOP_K_FINAL=5

# Authenticity weighting (Pillar 3) — multiplies retrieval score by grade.
NUR_GRADE_WEIGHT_SAHIH=1.30   # +30% (Authentic)
NUR_GRADE_WEIGHT_HASAN=1.10   # +10% (Good)
NUR_GRADE_WEIGHT_DAIF=0.50    # -50% (Weak — last resort, requires warning)
NUR_GRADE_WEIGHT_MAWDU=0.00   # excluded (Fabricated — kept for detection only)

# ----- Generation -----
# Temperature MUST stay at 0.0 — any stochasticity risks Quranic hallucination.
NUR_LLM_TEMPERATURE=0.0
NUR_LLM_MAX_TOKENS=2048
# Frequency penalty MUST be 0 — non-zero corrupts Arabic formulas.
NUR_LLM_FREQUENCY_PENALTY=0.0
NUR_LLM_REPETITION_PENALTY=1.1

# ----- Verification (Phase 4) -----
# NLI model for post-generation entailment check (Pillar 4, Module T4).
NUR_NLI_MODEL=cross-encoder/nli-deberta-v3-large
# Reject any sentence whose entailment score is below this threshold.
NUR_NLI_THRESHOLD=0.95

# ----- Misc -----
NUR_LOG_LEVEL=INFO
# Synthesis language for the Reporter LLM. Arabic text is ALWAYS displayed
# alongside the answer (Pillar 10) — this toggle only controls the FR/EN
# explanation layer. 'ar' is NOT a valid value here.
NUR_DEFAULT_LANG=en   # en | fr

# ============================================================
# NUR — Environment Variables
# Copy this file to `.env` and fill in your keys.
# All cloud APIs are FREE — no payment required.
# ============================================================

# ----- LLM Providers -----
# Groq — primary cloud LLM (https://console.groq.com)
# Free tier: 60 RPM, 1K RPD for Qwen3-32B
GROQ_API_KEY=

# OpenRouter — fallback if Groq is down (https://openrouter.ai)
# Free Qwen3-32B available
OPENROUTER_API_KEY=

# Ollama — local fallback (no key needed, runs on localhost)
# Default URL: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ----- Model Selection -----
# Primary cloud model — Qwen3-32B (best Arabic on free Groq tier)
NUR_LLM_PRIMARY=qwen/qwen3-32b
# Reasoning model — Qwen3.6-27B for complex fiqh questions
NUR_LLM_REASONING=qwen/qwen3.6-27b
# Local fallback model — Qwen2.5-7B via Ollama
NUR_LLM_LOCAL=qwen2.5:7b

# ----- Embeddings -----
# BGE-M3 — dense (1024-dim) + sparse + ColBERT, 8192 token context
NUR_EMBEDDING_MODEL=BAAI/bge-m3
NUR_EMBEDDING_DIM=1024

# Reranker — bge-reranker-v2-m3 (568M params, multilingual, runs on CPU)
NUR_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ----- Vector DB -----
# ChromaDB persistent path (local)
NUR_CHROMA_PATH=data/chroma_db

# ----- Retrieval Settings -----
# RRF fusion parameters (see docs/ARCHITECTURE.md Section 10)
# k=25 (lower than web-standard 60 — better for Islamic text)
# α=0.4 dense / 0.6 sparse (sparse dominates for exact references)
NUR_RRF_K=25
NUR_RRF_ALPHA_DENSE=0.4

# Top-K for retrieval stages
NUR_TOP_K_INITIAL=30   # after RRF fusion
NUR_TOP_K_RERANK=10    # after reranker
NUR_TOP_K_FINAL=5      # sent to LLM

# Authenticity weighting (Pilier 3)
NUR_GRADE_WEIGHT_SAHIH=1.30   # +30%
NUR_GRADE_WEIGHT_HASAN=1.10   # +10%
NUR_GRADE_WEIGHT_DAIF=0.50    # -50%
NUR_GRADE_WEIGHT_MAWDU=0.00   # excluded (kept for detection only)

# ----- Generation -----
NUR_LLM_TEMPERATURE=0.0
NUR_LLM_MAX_TOKENS=2048
NUR_LLM_FREQUENCY_PENALTY=0.0   # MUST be 0 — non-zero corrupts Arabic formulas
NUR_LLM_REPETITION_PENALTY=1.1

# ----- Verification (Phase 6) -----
# NLI model for post-generation verification
NUR_NLI_MODEL=cross-encoder/nli-deberta-v3-large
NUR_NLI_THRESHOLD=0.95

# ----- Misc -----
NUR_LOG_LEVEL=INFO
NUR_DEFAULT_LANG=en   # en | ar — response language if user's is ambiguous
